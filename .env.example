# PostgreSQL connection string
# For development: postgresql://user:password@localhost:5432/metrics
# For production (Neon): postgresql://user:password@endpoint.neon.tech/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/metrics

# Debug mode (false for production)
DEBUG=false

# Server port (optional, defaults to 8000)
PORT=8000
