{
  "buildCommand": "pip install -r backend/requirements.txt",
  "devCommand": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "envPrefix": "DATABASE_URL",
  "public": "frontend",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
